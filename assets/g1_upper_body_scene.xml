<mujoco model="g1_upper_body_scene">
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 1.0" extent="1.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane_stage1" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane_stage1" texture="groundplane_stage1" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor_stage1" size="0 0 0.05" type="plane" material="groundplane_stage1"/>
    
    <!-- Target visualization for right hand -->
    <site name="target_right" pos="0.3 -0.3 1.2" size="0.03" rgba="1 0 0 0.5" type="sphere"/>
    
    <!-- Fixed camera for RGBD -->
    <camera name="front_camera" pos="1.0 0 1.5" euler="-0.5 0 1.57" fovy="60"/>
  </worldbody>

  <equality>
    <!-- Freeze floating base: use robot as a fixed-base dual-arm system in stage 1 -->
    <weld body1="pelvis"/>
  </equality>

  <default>
    <geom friction="0.5"/>
  </default>
</mujoco>
